{
  "contributions": {
    "settings": [
      {
        "file_patterns": [
          "/LSP-wren-lsp.sublime-settings"
        ],
        "schema": {
          "$id": "sublime://settings/LSP-wren-lsp",
          "allOf": [
            {
              "$ref": "sublime://settings/LSP-plugin-base"
            },
            {
              "$ref": "sublime://settings/LSP-wren-lsp#/definitions/PluginConfig"
            }
          ],
          "definitions": {
            "PluginConfig": {
              "properties": {
                "settings": {
                  "additionalProperties": false,
                  "properties": {
                    "auto_download": {
                      "default": true,
                      "description": "Automatically download the latest wren-lsp binary from GitHub releases.",
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        }
      },
      {
        "file_patterns": [
          "/*.sublime-project"
        ],
        "schema": {
          "properties": {
            "settings": {
              "properties": {
                "LSP": {
                  "properties": {
                    "wren-lsp": {
                      "$ref": "sublime://settings/LSP-wren-lsp#/definitions/PluginConfig"
                    }
                  }
                }
              }
            }
          }
        }
      }
    ]
  }
}
